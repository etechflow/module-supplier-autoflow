<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Backend:etc/menu.xsd">
    <menu>
        <!-- The shared eTechFlow top-level (eTechFlow::root / settings / configuration)
             is declared by another eTechFlow module. Declaring it again here produced a
             duplicate 'uniqueAddItemId' that broke every admin page, so this module only
             parents its own item under eTechFlow::root and links it to the license gate. -->
        <add id="ETechFlow_SupplierAutoflow::root"
             title="Supplier Autoflow"
             module="ETechFlow_SupplierAutoflow"
             sortOrder="80"
             parent="eTechFlow::root"
             action="etechflow_saf/license/gate"
             resource="ETechFlow_SupplierAutoflow::config"/>
    </menu>
</config>
