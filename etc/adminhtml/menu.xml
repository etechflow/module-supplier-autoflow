<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Backend:etc/menu.xsd">
    <menu>
        <!--
            Shared eTechFlow top-level — declared identically by every
            eTechFlow module so Magento merges to one sidebar entry.
            See reference_etechflow_menu_convention.
        -->
        <add id="eTechFlow::root"
             title="eTechFlow"
             module="ETechFlow_SupplierAutoflow"
             sortOrder="68"
             resource="Magento_Backend::admin"/>

        <add id="eTechFlow::settings"
             title="Settings"
             module="ETechFlow_SupplierAutoflow"
             sortOrder="500"
             parent="eTechFlow::root"
             resource="Magento_Backend::admin"/>

        <add id="eTechFlow::configuration"
             title="Configuration"
             module="ETechFlow_SupplierAutoflow"
             sortOrder="10"
             parent="eTechFlow::settings"
             action="adminhtml/system_config/edit/section/etechflow_supplierautoflow"
             resource="Magento_Config::config"/>

        <!-- Supplier Autoflow module column. -->
        <add id="ETechFlow_SupplierAutoflow::root"
             title="Supplier Autoflow"
             module="ETechFlow_SupplierAutoflow"
             sortOrder="80"
             parent="eTechFlow::root"
             resource="ETechFlow_SupplierAutoflow::root"/>
    </menu>
</config>
