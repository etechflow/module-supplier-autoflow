<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="ETechFlow_SupplierAutoflow::root"
                          title="Supplier Autoflow"
                          sortOrder="50">
                    <resource id="ETechFlow_SupplierAutoflow::audit_log"
                              title="View Audit Log"
                              sortOrder="10"/>
                    <resource id="ETechFlow_SupplierAutoflow::config"
